{
  "name": "www.carlosmartos.com",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve --port 4321",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --no-watch",
    "analyze-bundle": "ng build --configuration=analyze-bundle && source-map-explorer dist/**/*.js --no-border-checks",
    "lint": "ng lint",
    "cy:run:local": "cypress run --env \"base_url=http://localhost:4321\" --browser chrome",
    "cy:run:local:firefox": "cypress run --env \"base_url=http://localhost:4321\" --browser firefox",
    "cy:test:local": "start-server-and-test start http-get://localhost:4321 cy:run:local",
    "cy:test:local:firefox": "start-server-and-test start http-get://localhost:4321 cy:run:local:firefox",
    "cy:open:local": "cypress open --env \"base_url=http://localhost:4321\"",
    "cy:run:prod": "cypress run --env \"base_url=https://www.carlosmartos.com\"",
    "cy:open:prod": "cypress open --env \"base_url=https://www.carlosmartos.com\""
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/platform-server": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@angular/ssr": "^22.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^22.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "angular-eslint": "^21.3.1",
    "cypress": "^15.14.2",
    "eslint": "^10.3.0",
    "jsdom": "^29.1.1",
    "schema-dts": "^2.0.0",
    "source-map-explorer": "^2.5.3",
    "start-server-and-test": "^3.0.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "glob": "^11.0.3"
  }
}
